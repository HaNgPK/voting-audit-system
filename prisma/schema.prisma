// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // Bắt buộc để dùng adapter của Neon DB
}

datasource db {
  provider = "postgresql"
  // KHÔNG thêm url ở đây, Prisma 7 sẽ đọc từ prisma.config.ts
}

// 1. NGƯỜI DÙNG
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("AUDITOR") // ADMIN, AUDITOR, VIEWER
  address   String?  // Địa chỉ người dùng

  // Liên kết N-N: Một kiểm phiếu viên có thể nằm trong nhiều Tổ
  teams     Team[]   @relation("TeamAuditors")
  audits    Audit[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// 2. TỔ KIỂM PHIẾU (Thay cho Group)
model Team {
  id        String   @id @default(cuid())
  name      String
  
  // Liên kết N-N
  auditors  User[]   @relation("TeamAuditors")
  ballots   Ballot[] @relation("TeamBallots") // Các danh sách bầu cử tổ này phải kiểm
  
  // Liên kết 1-N
  voters    Voter[]  // Danh sách cử tri của tổ
  audits    Audit[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

// 3. DANH SÁCH BẦU CỬ (Thay cho BallotType)
model Ballot {
  id          String      @id @default(cuid())
  name        String      // VD: Đơn vị bầu cử Xã số 01
  level       String      // Cấp độ: QUOCHOI, THANHPHO, XA
  description String?
  
  candidates  Candidate[]
  teams       Team[]      @relation("TeamBallots")
  audits      Audit[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("ballots")
}

// 4. ỨNG CỬ VIÊN
model Candidate {
  id          String   @id @default(cuid())
  name        String
  birthYear   Int      // Năm sinh
  gender      String   // Nam / Nữ
  index       Int      // Số thứ tự trong danh sách
  voteCount   Int      @default(0)
  
  ballotId    String
  ballot      Ballot   @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@unique([ballotId, index]) // Chống trùng số thứ tự trong cùng 1 danh sách
  @@map("candidates")
}

// 5. CỬ TRI (Bảng mới)
model Voter {
  id       String  @id @default(cuid())
  name     String
  address  String?
  idNumber String? // CMND/CCCD
  
  teamId   String
  team     Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("voters")
}

// 6. LỊCH SỬ KIỂM PHIẾU (Giữ nguyên logic Audit cũ của bạn)
model Audit {
  id          String   @id @default(cuid())
  
  ballotId    String
  ballot      Ballot   @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  candidateId String?
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("audits")
}