// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String
  role      UserRole   @default(AUDITOR)
  groups    Group[]    @relation("UserGroups")
  audits    Audit[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

model Group {
  id          String     @id @default(cuid())
  name        String
  commune     String
  code        String     @unique
  users       User[]     @relation("UserGroups")
  ballots     Ballot[]
  audits      Audit[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("groups")
}

model BallotType {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  ballots     Ballot[]
  candidates Candidate[]
  createdAt   DateTime   @default(now())

  @@map("ballot_types")
}

model Candidate {
  id            String      @id @default(cuid())
  name          String
  ballotTypeId  String
  ballotType    BallotType  @relation(fields: [ballotTypeId], references: [id], onDelete: Cascade)
  order         Int
  voteCount     Int         @default(0)
  createdAt     DateTime    @default(now())

  @@unique([ballotTypeId, order])
  @@map("candidates")
}

model Ballot {
  id           String       @id @default(cuid())
  groupId      String
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ballotTypeId String
  ballotType   BallotType   @relation(fields: [ballotTypeId], references: [id], onDelete: Cascade)
  ballotNumber Int
  status       BallotStatus @default(PENDING)
  audits       Audit[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([groupId, ballotTypeId, ballotNumber])
  @@map("ballots")
}

model Audit {
  id          String    @id @default(cuid())
  ballotId    String
  ballot      Ballot    @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  candidateId String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("audits")
}

enum UserRole {
  ADMIN
  AUDITOR
  VIEWER
}

enum BallotStatus {
  PENDING
  AUDITED
  COMPLETE
}